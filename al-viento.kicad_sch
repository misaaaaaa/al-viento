	(text "Se me ocurrió de repente, dijo Amalfitano, la idea es de\nDuchamp, dejar un libro de geometría colgado a la intemperie\npara ver si aprende cuatro cosas de la vida real. Lo vas a\ndestrozar, dijo Rosa. Yo no, dijo Amalfitano, la naturaleza.\n\nBolaño, 2666\n"
		(exclude_from_sim no)
		(at 242.57 152.4 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
